# Django Backend Environment Variables
# Copy to .env and fill in real values

# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-app.up.railway.app,localhost

# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# CORS — your Vercel frontend domain
CORS_ALLOWED_ORIGINS=https://your-portfolio.vercel.app,http://localhost:5173

# Email (contact form notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
ADMIN_EMAIL=mustaphahaadi04@gmail.com
